{
  "name": "voice-claude-code",
  "displayName": "Voice to Claude Code",
  "description": "Dictate text into Claude Code using local Whisper transcription",
  "version": "0.1.0",
  "publisher": "local",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:voiceClaude.startRecording"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "voiceClaude.startRecording",
        "title": "Voice: Start Recording",
        "icon": "$(mic)"
      }
    ],
    "keybindings": [
      {
        "command": "voiceClaude.startRecording",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
